<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>DESDE QUE SALVO ESTOY</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>1</br>
        <br>Yo tengo un himno de loor,</br>
        <br>Desde que salvo estoy,</br>
        <br>Para mi Rey, mi Salvador,</br>
        <br>Desde que salvo estoy.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>//Desde que salvo estoy//</br>
        <br>Sólo en él me gloriaré;</br>
        <br>Desde que salvo estoy,</br>
        <br>En mi Salvador me gloriaré.</br>
        <br>2</br>
        <br>Yo tengo un Cristo, y mi ansiedad</br>
        <br>Desde que salvo estoy,</br>
        <br>Está en cumplir su voluntad</br>
        <br>Desde que salvo estoy.</br>
        <br>Yo tengo un gozo que él me dio,</br>
        <br>Desde que salvo estoy,</br>
        <br>Cuando en su sangre me lavó</br>
        <br>Desde que salvo estoy.</br>
        <br>3</br>
        <br>Tengo un hogar a donde iré,</br>
        <br>Desde que salvo estoy,</br>
        <br>Y allí seguro viviré</br>
        <br>Desde que salvo estoy.</br>
        <br>196. ¿QUÈ ME PUEDE DAR PERDON?</br>
        <br>¿Qué me puede dar perdón?</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>¿Y un nuevo corazón?</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Precioso es el raudal</br>
        <br>Que limpia todo mal;</br>
        <br>No hay otro manantial,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Fue el rescate eficaz,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Trajo santidad y paz,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Veo para mi salud,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Tiene de sanar virtud,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>Cantaré junto a sus pies,</br>
        <br>¡Sólo de Jesús la sangre!</br>
        <br>El Cordero digno es,</br>
        <br>¡Sólo de Jesús la sangre!</br>
      </lines>
    </verse>
  </lyrics>
</song>
