<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>TUYO SOY</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>, JESUS</br>
        <br>Tuyo soy, Jesús, pue oí tu voz,</br>
        <br>En amor llámome a mí,</br>
        <br>Mas anhelo en alas de fe subir,</br>
        <br>Y más cerca estar de ti.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>Aún más cerca, cerca de tu cruz,</br>
        <br>Llévame, ¡Oh Salvador!</br>
        <br>Aún más cerca, cerca, cerca, de tu cruz,</br>
        <br>Viva yo, ¡oh buen Pastor!</br>
        <br>A seguirte a ti me consagro hoy,</br>
        <br>Constreñido por tu amor,</br>
        <br>Y mi Espíritu, alma cuerpo doy</br>
        <br>Por servirte mi Señor.</br>
        <br>¡Oh, cuán pura y santa delicia es</br>
        <br>De tu comunión gozar;</br>
        <br>Conversar contigo, y tu dulce voz</br>
        <br>Cada día escuchar!</br>
        <br>De tu grande amor no comprenderé</br>
        <br>Cuál es la profundidad,</br>
        <br>Hasta que contigo, Jesús, este</br>
        <br>En gloriosa eternidad.</br>
      </lines>
    </verse>
  </lyrics>
</song>
