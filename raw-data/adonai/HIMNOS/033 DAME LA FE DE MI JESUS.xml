<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>DAME LA FE DE MI JESUS</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Dame la fe de mi Jesús,</br>
        <br>La fe bendita del Señor,</br>
        <br>Que al afligido dé la paz,</br>
        <br>La fe que salva de temor;</br>
        <br>Fe de los santos galardón,</br>
        <br>Gloriosa  fe de salvación.</br>
        <br>Dame la fe que trae poder</br>
        <br>De los demonios vencedor;</br>
        <br>Que fieras no podrán vencer,</br>
        <br>Ni dominarla el opresor,</br>
        <br>Que pueda hogueras soportar,</br>
        <br>Premio de mártir alcanzar.</br>
        <br>Dame la fe que vencerá,</br>
        <br>En todo tiempo, mi Jesús;</br>
        <br>Dame la fe que fijará</br>
        <br>Mi vista en tu divina cruz;</br>
        <br>Que puede proclamar tu amor,</br>
        <br>Tu voluntad hacer, Señor.</br>
        <br>Dame la fe que da el valor,</br>
        <br>Que ayuda al débil triunfar,</br>
        <br>Que todo sufre con amor,</br>
        <br>Y puede en el dolor cantar,</br>
        <br>Que pueda el cielo escalar,</br>
        <br>O aquí con Cristo caminar.</br>
      </lines>
    </verse>
  </lyrics>
</song>
