<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>TE LOAMOS</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>, ¡OH DIOS!</br>
        <br>Te loamos, oh Dios,</br>
        <br>Con unánime voz,</br>
        <br>Que en Cristo tu hijo</br>
        <br>Nos diste perdón</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>¡Aleluya! Te alabamos,</br>
        <br>¡Cuán grande es tu amor!</br>
        <br>¡Aleluya! Te adoramos,</br>
        <br>Bendito Señor.</br>
        <br>Te loamos, Jesús,</br>
        <br>Quien tu trono de luz</br>
        <br>Has dejado por darnos</br>
        <br>Salud en la cruz.</br>
        <br>Te damos loor,</br>
        <br>Santo Consolador,</br>
        <br>Que nos llenas de gozo</br>
        <br>Y santo valor.</br>
        <br>Unidos load</br>
        <br>A la gran trinidad,</br>
        <br>Que es la fuente de gracia,</br>
        <br>Virtud y verdad.</br>
        <br>145. ¡TRABAJAD, TRABAJAD!</br>
        <br>¡Trabajad, trabajad! Somos siervos de Dios,</br>
        <br>Seguiremos la senda que el Maestro trazó;</br>
        <br>Renovando las fuerzas con bienes que da,</br>
        <br>El deber que nos toca cumplido será.</br>
        <br>¡Trabajad, trabajad!</br>
        <br>¡Esperad, y velad!</br>
        <br>¡Confiad! ¡Siempre orad!</br>
        <br>¡Que el Maestro pronto volverá!</br>
        <br>¡Trabajad, trabajad! Hay que dar de comer</br>
        <br>Al que pan de la vida quisiere tener;</br>
        <br>Hay enfermos que irán a los pies del Señor</br>
        <br>Al saber que de balde los sana su amor.</br>
        <br>¡Trabajad, trabajad! Fortaleza pedid,</br>
        <br>El reinado del mal con valor combatid;</br>
        <br>Conducid los cautivos al Libertador</br>
        <br>Y decid que de balde redime su amor.</br>
      </lines>
    </verse>
  </lyrics>
</song>
