<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>SANTA BIBLIA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>1</br>
        <br>¡Santa Biblia! Para mí,</br>
        <br>Eres un tesoro aquí;</br>
        <br>Tú contienes con verdad</br>
        <br>La divina voluntad;</br>
        <br>Tú me dices lo que soy,</br>
        <br>De quién vine y a quién voy.</br>
        <br>Tú reprendes mi dudar;</br>
        <br>Tú me exhortas sin cesar;</br>
        <br>Eres faro que, a mi pie,</br>
        <br>Vas guiando por la fe,</br>
        <br>A las fuentes del amor</br>
        <br>Del Bendito Salvador.</br>
        <br>2</br>
        <br>Eres infalible voz</br>
        <br>Del Espíritu de Dios,</br>
        <br>Que vigor al alma da</br>
        <br>Cuando en aflicción está;</br>
        <br>Tú me enseñas a triunfar,</br>
        <br>De la muerte y el pecar.</br>
        <br>3</br>
        <br>Por tu santa letra sé</br>
        <br>Que con Cristo reinaré</br>
        <br>Yo que tan indigno soy,</br>
        <br>Por tu luz al cielo voy;</br>
        <br>¡Santa Biblia para mí,</br>
        <br>Eres un tesoro aquí!</br>
      </lines>
    </verse>
  </lyrics>
</song>
