<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>SUBLIME GRACIA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Sublime gracia del Señor,</br>
        <br>Que, a un infeliz, salvo,</br>
        <br>Yo ciego fui, más veo ya</br>
        <br>Perdido y El me hallo</br>
        <br>En los peligros o aflicción,</br>
        <br>Que yo he tenido aquí,</br>
        <br>Su gracia siempre me libró,</br>
        <br>Y me guiará feliz.</br>
        <br>Y cuando en Sion por siglos mil,</br>
        <br>Brillando esté cual sol,</br>
        <br>Yo cantaré por siempre allí,</br>
        <br>Su amor que me salvó (bis)</br>
      </lines>
    </verse>
  </lyrics>
</song>
