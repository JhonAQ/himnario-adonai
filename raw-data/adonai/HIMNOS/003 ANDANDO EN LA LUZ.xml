<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>ANDANDO EN LA LUZ</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Vagaba yo en oscuridad</br>
        <br>Mas cuando vi a Jesús,</br>
        <br>Por su evangelio de verdad</br>
        <br>Me amaneció la luz.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>Gozo y luz hay en mi alma hoy,</br>
        <br>Gozo y luz hay, ya que salvo soy;</br>
        <br>Desde que a Jesús vi,</br>
        <br>Y a su lado fui,</br>
        <br>Siento el grande gozo de su amor en mí.</br>
        <br>Las nubes y la tempestad</br>
        <br>No ocultan a Jesús,</br>
        <br>El mundo yace en su maldad</br>
        <br>Mas ando yo en su luz.</br>
        <br>Andando en la luz de Dios</br>
        <br>Encuentro plena paz;</br>
        <br>Voy adelante sin temor</br>
        <br>Dejando al mundo atrás.</br>
        <br>Veréle pronto tal cual es:</br>
        <br>Raudal de pura luz;</br>
        <br>Y eternamente gozaré</br>
        <br>A causa de su cruz.</br>
      </lines>
    </verse>
  </lyrics>
</song>
