<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>GLORIA A DIOS EN LAS ALTURAS</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>¡Gloria a Dios en las alturas,</br>
        <br>Que mostró su gran amor!</br>
        <br>Dando a humanas criaturas</br>
        <br>Un potente Salvador.</br>
        <br>Con los himnos de los santos</br>
        <br>Hagan coro nuestros cantos</br>
        <br>De alabanza y gratitud</br>
        <br>Por la celestial salud,</br>
        <br>Y digamos a una voz:</br>
        <br>¡En los cielos gloria a Dios!</br>
        <br>¡Gloria a Dios! La tierra cante</br>
        <br>Al gozar de su bondad,</br>
        <br>Pues le brinda paz constante</br>
        <br>En su buena voluntad.</br>
        <br>Toda tribu y lenguas todas</br>
        <br>Al Excelso eleven odas</br>
        <br>Por el Rey Emmanuel</br>
        <br>Que les vino de Israel;</br>
        <br>Y prorrumpan a una voz;</br>
        <br>¡En los cielos gloria a Dios!</br>
        <br>¡Gloria a Dios la iglesia entona,</br>
        <br>Rota al ver su esclavitud,</br>
        <br>Por Jesús, que es su corona,</br>
        <br>Su cabeza y plenitud.</br>
        <br>Vigilante siempre vive</br>
        <br>Y a la lucha se apercibe</br>
        <br>Mientras llega su solaz</br>
        <br>En la gloria y plena paz;</br>
        <br>Donde exclama a una voz:</br>
        <br>¡En los cielos gloria a Dios!</br>
      </lines>
    </verse>
  </lyrics>
</song>
