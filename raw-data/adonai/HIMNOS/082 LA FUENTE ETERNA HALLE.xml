<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>LA FUENTE ETERNA HALLE</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Por fe contemplo redención,</br>
        <br>La fuente carmesí;</br>
        <br>Jesús nos da salvación,</br>
        <br>Su vida dio por mí.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>La fuente sin igual,</br>
        <br>De vida y luz el manantial;</br>
        <br>¡Oh gloria a Dios, me limpia a mí,</br>
        <br>Me limpia a mí, me limpia a sí!</br>
        <br>Mi vida entrego a mi Jesús,</br>
        <br>Las dudas ya se van;</br>
        <br>Mi alma goza en su luz,</br>
        <br>Mis deudas él pago.</br>
        <br>¡Cuán inefable gozo es</br>
        <br>Saber que salvo soy!</br>
        <br>Mi rey aquí es mi Jesús,</br>
        <br>Al cielo se que voy.</br>
        <br>¡Oh gracia excelsa de mi Dios,</br>
        <br>Profundo es el amor!</br>
        <br>De mi Jesús, Mi buen Jesús,</br>
        <br>Cordero Redentor.</br>
      </lines>
    </verse>
  </lyrics>
</song>
