<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>AL CRISTO VIVO SIRVO</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Al Cristo vivo sirvo</br>
        <br>Y el en el mundo está;</br>
        <br>Aunque otros le negaren</br>
        <br>Yo sé que él vive ya</br>
        <br>Su mano tierna veo,</br>
        <br>Su voz consuelo da,</br>
        <br>Y cuando yo le llamo</br>
        <br>Muy cerca está.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>Él vive, él vive,</br>
        <br>Hoy vive el salvador;</br>
        <br>Conmigo está y me guardará</br>
        <br>Mi amante redentor.</br>
        <br>Él vive, él vive,</br>
        <br>Me imparte salvación;</br>
        <br>Sé que él viviendo está porque</br>
        <br>Vive en mi corazón.</br>
        <br>En todo el mundo entero</br>
        <br>Contemplo yo su amor,</br>
        <br>Y al sentirme triste;</br>
        <br>Consuélame el Señor;</br>
        <br>Seguro estoy que Cristo</br>
        <br>Mi vida guiando está,</br>
        <br>Y que otra vez al mundo</br>
        <br>Regresará.</br>
        <br>Regocijaos, cristianos,</br>
        <br>Hoy himnos entonad;</br>
        <br>Eternas aleluyas</br>
        <br>A Cristo el Rey cantad.</br>
        <br>Ayuda y esperanza</br>
        <br>Es del mundo pecador,</br>
        <br>No hay otro tan amante</br>
        <br>Como el Señor.</br>
      </lines>
    </verse>
  </lyrics>
</song>
