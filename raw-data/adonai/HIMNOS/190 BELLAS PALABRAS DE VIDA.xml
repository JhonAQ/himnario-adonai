<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>BELLAS PALABRAS DE VIDA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>¡Oh, cantádmelas otra vez!</br>
        <br>Bellas palabras de vida;</br>
        <br>Hallo en ellas mi gozo y luz,</br>
        <br>Bellas palabras de vida;</br>
        <br>Sí, de luz y vida;</br>
        <br>Son sostén y guía:</br>
        <br>//¡Qué bellas son, qué bellas son!</br>
        <br>Bellas palabras de vida. //</br>
        <br>Jesucristo a todos da</br>
        <br>Bellas palabras de vida;</br>
        <br>Hoy escúchalas, pecador,</br>
        <br>Bellas palabras de vida;</br>
        <br>Bondadoso te salva,</br>
        <br>Y al cielo te llama:</br>
        <br>//¡Qué bellas son, qué bellas son!</br>
        <br>Bellas palabras de vida. //</br>
        <br>Grato el cántico sonará,</br>
        <br>Bellas palabras de vida;</br>
        <br>Tus pecados perdonará,</br>
        <br>Bellas palabras de vida;</br>
        <br>Sí, de luz y vida,</br>
        <br>Son sostén y guía:</br>
        <br>//¡Qué bellas son, qué bellas son!</br>
        <br>Bellas palabras de vida. //</br>
      </lines>
    </verse>
  </lyrics>
</song>
