<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>LA SANTA CENA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Santa cena, para mí</br>
        <br>Eres memorial aquí;</br>
        <br>Tú me enseñas con verdad</br>
        <br>El misterio de bondad;</br>
        <br>Me recuerda de la cruz,</br>
        <br>Del cordero, mi Jesús.</br>
        <br>Tú elevas nuestro ser</br>
        <br>Al angélico placer;</br>
        <br>Tipificas con señal</br>
        <br>La crucifixión pascual.</br>
        <br>Comulguemos al tomar</br>
        <br>De Jesús y su penar.</br>
        <br>Participe del corazón</br>
        <br>De tu conmemoración;</br>
        <br>Nos recuerdas el partir</br>
        <br>De Jesús y su venir;</br>
        <br>Eres tú nuestra señal</br>
        <br>De su pacto divinal.</br>
        <br>Como sello del amor</br>
        <br>Del divino Redentor,</br>
        <br>Volveremos a tomar,</br>
        <br>Y con Cristo disfrutar,</br>
        <br>De la cena del Señor,</br>
        <br>Prenda fiel del viador</br>
      </lines>
    </verse>
  </lyrics>
</song>
