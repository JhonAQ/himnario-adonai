<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>BAJA DEL CIELO BENDITO FUEGO</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>1</br>
        <br>Fuego divino, clamamos por ti,</br>
        <br>Baja de lo alto, desciende aquí;</br>
        <br>Oh ven, despiértanos con tu fulgor</br>
        <br>Ven, vivifícanos con tu calor</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>Baja del cielo, bendito fuego,</br>
        <br>Baja, poder celestial;</br>
        <br>Baja del cielo, bendito fuego,</br>
        <br>Ven, llama Pentecostal.</br>
        <br>2</br>
        <br>Desciende, Espíritu Consolador</br>
        <br>Desciende y llénanos de santo amor,</br>
        <br>Al mundo baja cual dijo Jesús</br>
        <br>Danos poder, vida, gracia y luz.</br>
        <br>3</br>
        <br>Al mundo baja cual dijo el Señor,</br>
        <br>Arde en mi pecho y dame valor;</br>
        <br>Consume todos los restos del mal,</br>
        <br>Desciende hoy, fuego Pentecostal.</br>
      </lines>
    </verse>
  </lyrics>
</song>
