<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>CANTA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>, ¡OH BUEN CRISTIANO!</br>
        <br>¡Canta, oh buen cristiano</br>
        <br>Dulce será cantar,</br>
        <br>Hace el camino llano,</br>
        <br>Libra el pesar.</br>
        <br>Canta en las noches tristes,</br>
        <br>Canta en el sol y en luz;</br>
        <br>El mal así resistes,</br>
        <br>Canta de Jesús.</br>
        <br>¡Canta, oh buen cristiano!</br>
        <br>Templa tu corazón;</br>
        <br>Alza a tu soberano,</br>
        <br>Tu feliz canción.</br>
        <br>Siempre está lleno el mundo</br>
        <br>De endechas y dolor;</br>
        <br>Canta el amor profundo</br>
        <br>De tu salvador.</br>
        <br>¡Canta, oh buen cristiano!</br>
        <br>Dios tu socorro es,</br>
        <br>El sostendrá tu mano,</br>
        <br>Hasta la vejez.</br>
        <br>¿Sabes que al diablo invitas,</br>
        <br>Cuando medroso estás?</br>
        <br>Dios quitará tus penas</br>
        <br>Si cantando vas.</br>
      </lines>
    </verse>
  </lyrics>
</song>
