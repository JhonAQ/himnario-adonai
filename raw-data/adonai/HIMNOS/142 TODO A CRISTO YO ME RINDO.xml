<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>TODO A CRISTO YO ME RINDO</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Todo a Cristo yo me rindo</br>
        <br>Con el fin de serle fiel;</br>
        <br>Para siempre quiero amarle,</br>
        <br>Y agradarle sólo a Él.</br>
      </lines>
    </verse>
    <verse name="c">
      <lines>
        <br>Yo me rindo a Él,</br>
        <br>Yo me rindo a Él,</br>
        <br>Todo a Cristo yo me entrego,</br>
        <br>Quiero serle fiel.</br>
        <br>Todo a Cristo yo me rindo,</br>
        <br>A sus pies postrado, estoy,</br>
        <br>Los placeres he dejado,</br>
        <br>Y le sigo desde hoy.</br>
        <br>Todo a Cristo yo me rindo,</br>
        <br>Sí, de todo corazón;</br>
        <br>Yo le entrego alma y cuerpo,</br>
        <br>Busco hoy su santa unción.</br>
        <br>Todo a Cristo he rindo,</br>
        <br>Siento el fuego de su amor,</br>
        <br>¡Oh, qué gozo hay en mi alma!</br>
        <br>¡Gloria, gloria a mi Señor!</br>
      </lines>
    </verse>
  </lyrics>
</song>
