<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>AMOROSO SALVADOR</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Amoroso Salvador,</br>
        <br>Sin igual es tu bondad,</br>
        <br>Eres tú mi mediador,</br>
        <br>Mi perfecta santidad.</br>
        <br>Mi contrito corazón</br>
        <br>Te confiesa su maldad;</br>
        <br>Pide al Padre mi perdón</br>
        <br>Por tu santa caridad.</br>
        <br>Te contemplo sin cesar</br>
        <br>En tu trono desde aquí;</br>
        <br>¡Oh!, cuan grato es meditar</br>
        <br>Que intercedes tú por mí.</br>
        <br>¡Fuente tú de compasión!</br>
        <br>Siempre a ti te doy loor;</br>
        <br>Siendo grato al corazón</br>
        <br>Ensalzarte, ¡mi Señor!</br>
      </lines>
    </verse>
  </lyrics>
</song>
