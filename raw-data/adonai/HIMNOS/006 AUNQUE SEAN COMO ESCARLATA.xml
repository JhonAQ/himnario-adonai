<?xml version="1.0" encoding="utf-8"?>
<song xmlns="http://openlyrics.info/namespace/2009/song">
  <properties>
    <titles>
      <title>AUNQUE SEAN COMO ESCARLATA</title>
    </titles>
    <authors>
      <author>DESCONOCIDO</author>
    </authors>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>
        <br>Aunque sean como escarlata,</br>
        <br>Tus pecados lavaré,</br>
        <br>Y si fueren como grana</br>
        <br>Níveos  los haré</br>
        <br>//Aunque sean como escarlata,</br>
        <br>Tus pecados lavaré.//</br>
        <br>Oye voz que te suplica:</br>
        <br>Vuelve, vuelve a tu Señor.</br>
        <br>Bueno es Él, compasivo,</br>
        <br>Y de tierno amor.</br>
        <br>//Oye tu voz que te suplica:</br>
        <br>Vuelve, vuelve a tu Señor. //</br>
        <br>Él aleja tus pecados</br>
        <br>Y su consecuencia atroz:</br>
        <br>“Venid a mí, y sed salvos”,</br>
        <br>Dice nuestro Dios.</br>
        <br>Él aleja tus pecados</br>
        <br>Y consecuencia atroz;</br>
        <br>//Él aleja tus pecados</br>
        <br>Y su consecuencia atroz. //</br>
      </lines>
    </verse>
  </lyrics>
</song>
